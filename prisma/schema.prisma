generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH / ROLE
// ============================================================================

model AllRole {
  id              String           @id @default(uuid())
  role            String?
  description     String?
  isActive        Boolean          @default(true)
  // Null = global role created by Platform Super Admin (e.g. SUPER_ADMIN).
  // Non-null = role created by a Branch Super Admin for their own tenant;
  // other tenants cannot see or use it.

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("all_roles")
}

model RolePermission {
  id          String   @id @default(uuid())
  roleId      String?
  module      String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  role        AllRole? @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("role_permissions")
}

model Department {
  id          String   @id @default(uuid())

  name        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@map("departments")
}

// ============================================================================
// ORGANIZATION (Branches & SubBranches)
// ============================================================================

// MainBranch = a company (= one customer tenant). Kept `@@map("branches")`
// so the existing `branches` table and all its data are reused — only the
// Prisma model name changed, not the database table.




model Designation {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  description String?
  // Null = global designation created by Platform Super Admin. Non-null
  // = designation created by a Branch Super Admin for their own tenant.

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  users       User[]
}

// ============================================================================
// USER (with auth tokens & device tracking)
// ============================================================================

model User {
  id            String       @id @default(uuid())
  email         String?      @unique
  password      String?
  mobile        String?      @unique
  roleId        String?
  role          AllRole?     @relation(fields: [roleId], references: [id])
  designationId String?

  // ---- Auth & device tracking ----
  refreshToken      String?
  currentDeviceId   String?
  currentDeviceName String?
  currentDeviceType String?
  currentIpAddress  String?
  currentUserAgent  String?

  // ---- Status flags ----
  isActive           Boolean   @default(true)
  isBlocked          Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  isVerified         Boolean   @default(false)
  passwordChanged    Boolean   @default(false)
  passwordChangeTime DateTime?
  // Set to true when this user's role permissions change; the next
  // /users/my-data fetch reads + clears it, forcing a frontend reload
  // so the sidebar/route guards re-evaluate against the new grants.
  forceReload        Boolean   @default(false)

  // ---- Login meta ----
  lastLogin     DateTime? @default(now())
  loginCount    Int       @default(0)
  loginTryCount Int       @default(0)
  loginTryTime  DateTime? @default(now())

  // ---- FKs ----
  departmentId   String?


  // ---- Timestamps ----
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ---- Relations ----
  address            Address?
  profile            Profile?
  workInfo           WorkInfo?
  department         Department?        @relation(fields: [departmentId], references: [id])

  comments           Comment[]
  notifications      Notification[]

  loginHistories     LoginHistory[]
  designation   Designation? @relation(fields: [designationId], references: [id])

  @@map("users")
}

// ============================================================================
// LOGIN HISTORY (full audit trail per device / event)
// ============================================================================

model LoginHistory {
  id     String       @id @default(uuid())
  userId String?
  status LoginStatus? @default(SUCCESS)

  // ---- Device info ----
  deviceId       String?
  deviceName     String?
  deviceType     String?
  os             String?
  osVersion      String?
  browser        String?
  browserVersion String?
  userAgent      String?

  // ---- Network info ----
  ipAddress String?
  location  String?
  country   String?
  city      String?

  // ---- Event info ----
  failureReason String?
  loggedInAt    DateTime? @default(now())
  loggedOutAt   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@map("login_histories")
}

// ============================================================================
// PROFILE / ADDRESS / WORK INFO
// ============================================================================

model Profile {
  id            String      @id @default(uuid())
  mobile        String?     @unique
  name          String?
  gender        Gender?
  age           Int?
  dob           DateTime?
  bloodGroup    BloodGroup?
  photoId       String?
  profilePhoto  Image?      @relation("ProfilePhoto", fields: [photoId], references: [id])
  photo         String?
  nid           String?
  nidPhoto      String[]    @default([])
  nidPhotos     Image[]     @relation("NidPhotos")
  emailVerified Boolean     @default(false)
  phoneVerified Boolean     @default(false)
  nidVerified   Boolean     @default(false)
  serialId      String?
  user          User?       @relation(fields: [mobile], references: [mobile])

  @@map("profiles")
}

model Address {
  id       String  @id @default(uuid())
  mobile   String? @unique
  division String?
  district String?
  upazila  String?
  address  String?
  user     User?   @relation(fields: [mobile], references: [mobile])

  @@map("addresses")
}

model WorkInfo {
  id                 String        @id @default(uuid())
  mobile             String?       @unique
  subCategories      SubCategory[]
  experience         String?


  workStartTime      String?
  workTimeLimit      String?
  availableTime      String?
  isDeleted          Boolean       @default(false)
  isBlocked          Boolean       @default(false)
  passwordChangeTime DateTime?
  passwordChanged    Boolean       @default(false)
  verified           Boolean       @default(false)
  user               User?         @relation(fields: [mobile], references: [mobile])

  @@map("work_infos")
}

// ============================================================================
// SUBSCRIPTION / PAYMENT
// ============================================================================





// SubscriptionPlan = reusable template the Platform Super Admin defines
// once (e.g. "Pro Monthly", "Lifetime Enterprise"). Companies pick from
// these when buying a subscription.


// Subscription = a specific company's (Branch's) active billing window
// against a Plan. Pure instance — all plan details (name, price, cycle,
// currency) come from the related SubscriptionPlan, never duplicated here.


// ============================================================================
// MISC
// ============================================================================

model Otp {
  id        String   @id @default(uuid())
  email     String?  @unique
  otpToken  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("otps")
}

model Category {
  id            String        @id @default(uuid())

  icon          String?
  description   String?
  name          String?
  slug          String?       @unique
  status        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subCategories SubCategory[]

  @@map("categories")
}

model SubCategory {
  id          String     @id @default(uuid())
  name        String?
  categoryId  String?
  description String?
  icon        String?
  slug        String?    @unique
  status      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  category    Category?  @relation(fields: [categoryId], references: [id])
  workInfos   WorkInfo[]

  @@map("sub_categories")
}



model Blog {
  id          String    @id @default(uuid())

  title       String?
  slug        String?   @unique
  content     String?
  description String?
  excerpt       String?
  coverImageId  String?
  coverImage    Image?    @relation("BlogCoverImage", fields: [coverImageId], references: [id])
  thumbnailId   String?
  thumbnail     Image?    @relation("BlogThumbnail", fields: [thumbnailId], references: [id])
  tags          String[]  @default([])
  category    String[]  @default([])
  authorId    String?
  authorName  String?
  authorImage String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt


  @@map("blogs")
}

model Folder {
  id        String   @id @default(uuid())

  name      String?
  slug      String?  @unique
  parentId  String?
  status       Boolean  @default(true)
  zoomFolderId Int?
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    Folder?  @relation("FolderToFolder", fields: [parentId], references: [id])
  children  Folder[] @relation("FolderToFolder")
  images    Image[]

  @@map("folders")
}

model Image {
  id                   String    @id @default(uuid())
  name                 String?
  url                  String?
  folderId             String?
  slug                 String?   @unique
  status               Boolean   @default(true)
  zoomFileId           Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  folder               Folder?   @relation(fields: [folderId], references: [id])
  profilePhotoProfiles Profile[] @relation("ProfilePhoto")
  nidPhotoProfiles     Profile[] @relation("NidPhotos")
  blogCoverImages      Blog[]    @relation("BlogCoverImage")
  blogThumbnails       Blog[]    @relation("BlogThumbnail")

  @@map("images")
}

model Comment {
  id        String   @id @default(uuid())

  userId    String?
  comment   String?
  isDeleted Boolean  @default(false)

  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Notification {
  id        String   @id @default(uuid())

  userId    String?
  type      String?
  message   String?
  isRead    Boolean  @default(false)
  isDeleted Boolean  @default(false)

  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  MAINTAINER
  OWNER
  USER
  WORKER
  EMPLOYEE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum LoginStatus {
  SUCCESS
  FAILED
  LOGOUT
  EXPIRED
}
